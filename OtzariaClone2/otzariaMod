use std::sync::Mutex;
use tauri::State;
use tantivy::collector::TopDocs;
use tantivy::query::QueryParser;
use tantivy::schema::*;
use tantivy::{Index, IndexWriter, ReloadPolicy};
use walkdir::WalkDir;
use std::fs;
use std::path::Path;
use std::process::Command;

struct AppState {
    index: Index,
    schema: Schema,
}

#[derive(serde::Serialize)]
struct TreeNode {
    name: String,
    path: Option<String>,
    children: Vec<TreeNode>,
}

fn build_tree(library_path: &str) -> TreeNode {
    let mut root = TreeNode { name: "Library".to_string(), path: None, children: vec![] };
    for entry in WalkDir::new(library_path).min_depth(1).into_iter().filter_map(|e| e.ok()) {
        let rel = entry.path().strip_prefix(library_path).unwrap_or(entry.path());
        let components: Vec<String> = rel.components().map(|c| c.as_os_str().to_string_lossy().to_string()).collect();

        let mut current = &mut root;
        for (i, comp) in components.iter().enumerate() {
            if i == components.len() - 1 && entry.path().is_file() && comp.ends_with(".txt") {
                let title = comp.replace(".txt", "");
                current.children.push(TreeNode {
                    name: title,
                    path: Some(entry.path().to_string_lossy().to_string()),
                    children: vec![],
                });
            } else if let Some(child) = current.children.iter_mut().find(|c| c.name == *comp) {
                current = child;
            } else {
                let new_node = TreeNode { name: comp.clone(), path: None, children: vec![] };
                current.children.push(new_node);
                current = current.children.last_mut().unwrap();
            }
        }
    }
    root
}

#[tauri::command]
fn get_library_tree() -> Result<TreeNode, String> {
    Ok(build_tree("./library"))
}

#[tauri::command]
fn import_official_library() -> Result<String, String> {
    let data_dir = "./data";
    let repo_dir = format!("{}/otzaria-library", data_dir);
    let target = "./library";

    std::fs::create_dir_all(data_dir).ok();
    std::fs::create_dir_all(target).ok();

    if Path::new(&repo_dir).exists() {
        let _ = Command::new("git").current_dir(&repo_dir).args(["pull", "--depth=1"]).output();
    } else {
        let output = Command::new("git")
            .args(["clone", "--depth=1", "https://github.com/Sivan22/otzaria-library.git", &repo_dir])
            .output()
            .map_err(|e| e.to_string())?;
        if !output.status.success() {
            return Err("Git clone failed. Is git installed?".to_string());
        }
    }

    let source = format!("{}/אוצריא", repo_dir);
    if Path::new(&source).exists() {
        let _ = Command::new("cp").args(["-r", "-T", &source, target]).output();
    }
    Ok("Official library imported!".to_string())
}

