#### `src-tauri/src/main.rs` (complete final backend)

```rust
use std::sync::Mutex;
use tauri::State;
use tantivy::collector::TopDocs;
use tantivy::query::QueryParser;
use tantivy::schema::*;
use tantivy::{Index, IndexWriter, ReloadPolicy};
use walkdir::WalkDir;
use std::fs;
use std::path::Path;
use std::process::Command;

struct AppState {
    index: Index,
    schema: Schema,
}

#[derive(serde::Serialize)]
struct TreeNode {
    name: String,
    path: Option<String>,
    children: Vec<TreeNode>,
}

fn build_tree(library_path: &str) -> TreeNode {
    let mut root = TreeNode { name: "Library".to_string(), path: None, children: vec![] };
    for entry in WalkDir::new(library_path).min_depth(1).into_iter().filter_map(|e| e.ok()) {
        let rel = entry.path().strip_prefix(library_path).unwrap_or(entry.path());
        let components: Vec<String> = rel.components()
            .map(|c| c.as_os_str().to_string_lossy().to_string())
            .collect();

        let mut current = &mut root;
        for (i, comp) in components.iter().enumerate() {
            if i == components.len() - 1 && entry.path().is_file() && comp.ends_with(".txt") {
                let title = comp.replace(".txt", "");
                current.children.push(TreeNode {
                    name: title,
                    path: Some(entry.path().to_string_lossy().to_string()),
                    children: vec![],
                });
            } else if let Some(child) = current.children.iter_mut().find(|c| c.name == *comp) {
                current = child;
            } else {
                let new_node = TreeNode { name: comp.clone(), path: None, children: vec![] };
                current.children.push(new_node);
                current = current.children.last_mut().unwrap();
            }
        }
    }
    root
}

#[tauri::command]
fn get_library_tree() -> Result<TreeNode, String> {
    Ok(build_tree("./library"))
}

#[tauri::command]
fn import_official_library() -> Result<String, String> {
    let data_dir = "./data";
    let repo_dir = format!("{}/otzaria-library", data_dir);
    let target = "./library";

    std::fs::create_dir_all(data_dir).ok();
    std::fs::create_dir_all(target).ok();

    if Path::new(&repo_dir).exists() {
        let _ = Command::new("git").current_dir(&repo_dir).args(["pull", "--depth=1"]).output();
    } else {
        let output = Command::new("git")
            .args(["clone", "--depth=1", "https://github.com/Sivan22/otzaria-library.git", &repo_dir])
            .output()
            .map_err(|e| e.to_string())?;
        if !output.status.success() {
            return Err("Git clone failed. Make sure git is installed.".to_string());
        }
    }

    let source = format!("{}/אוצריא", repo_dir);
    if Path::new(&source).exists() {
        let _ = Command::new("cp").args(["-r", "-T", &source, target]).output();
    }
    Ok("Official library imported successfully!".to_string())
}

#[tauri::command]
fn rebuild_library(state: State<Mutex<AppState>>) -> Result<String, String> {
    let state = state.lock().unwrap();
    let mut writer = state.index.writer(100_000_000).map_err(|e| e.to_string())?;
    let title_field = state.schema.get_field("title").unwrap();
    let body_field = state.schema.get_field("body").unwrap();

    writer.delete_all_documents().unwrap();

    for entry in WalkDir::new("./library").into_iter().filter_map(|e| e.ok()) {
        if entry.path().extension().map_or(false, |ext| ext == "txt") {
            let title = entry.path().file_stem().unwrap().to_string_lossy().to_string();
            if let Ok(body) = fs::read_to_string(entry.path()) {
                writer.add_document(doc!(
                    title_field => title,
                    body_field => body
                )).unwrap();
            }
        }
    }
    writer.commit().map_err(|e| e.to_string())?;
    Ok("Library indexed successfully!".to_string())
}

#[tauri::command]
fn load_book(path: String) -> Result<String, String> {
    fs::read_to_string(&path).map_err(|e| e.to_string())
}

#[tauri::command]
fn search(query: String, state: State<Mutex<AppState>>) -> Result<Vec<serde_json::Value>, String> {
    let state = state.lock().unwrap();
    let reader = state.index.reader_builder()
        .reload_policy(ReloadPolicy::OnCommit)
        .try_into().map_err(|e| e.to_string())?;
    let searcher = reader.searcher();
    let title = state.schema.get_field("title").unwrap();
    let body = state.schema.get_field("body").unwrap();

    let query_parser = QueryParser::for_index(&state.index, vec![title, body]);
    let q = query_parser.parse_query(&query).map_err(|e| e.to_string())?;
    let top_docs = searcher.search(&q, &TopDocs::with_limit(50)).map_err(|e| e.to_string())?;

    let mut results = Vec::new();
    for (_, addr) in top_docs {
        let doc = searcher.doc(addr).map_err(|e| e.to_string())?;
        let t = doc.get_first(title).and_then(|v| v.as_text()).unwrap_or("");
        let b = doc.get_first(body).and_then(|v| v.as_text()).unwrap_or("");
        let excerpt = if b.len() > 220 { format!("{}...", &b[..220]) } else { b.to_string() };
        results.push(serde_json::json!({ "title": t, "excerpt": excerpt, "full_text": b }));
    }
    Ok(results)
}

#[tauri::command]
fn normalize_ref(title: String) -> String {
    title.replace(" ", "_").replace("'", "").replace("\"", "").trim().to_lowercase()
}

fn main() {
    let mut schema_builder = Schema::builder();
    schema_builder.add_text_field("title", TEXT | STORED);
    schema_builder.add_text_field("body", TEXT | STORED);
    let schema = schema_builder.build();

    let index = Index::create_in_dir("./data/index", schema.clone())
        .or_else(|_| Index::create_in_ram(schema.clone()))
        .unwrap();

    let state = Mutex::new(AppState { index, schema });

    tauri::Builder::default()
        .manage(state)
        .invoke_handler(tauri::generate_handler![
            search, rebuild_library, load_book,
            import_official_library, get_library_tree, normalize_ref
        ])
        .run(tauri::generate_context!())
        .expect("error while running tauri application");
}
```

