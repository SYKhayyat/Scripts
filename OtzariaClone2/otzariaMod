            let rel_path = entry.path().strip_prefix("./library").unwrap_or(entry.path());
            let components: Vec<_> = rel_path.components().collect();

            let category = if components.len() > 1 {
                components[0].as_os_str().to_string_lossy().to_string()
            } else {
                "General".to_string()
            };

            let title = entry.path().file_stem().unwrap().to_string_lossy().to_string();
            let path = entry.path().to_string_lossy().to_string();

            books.push(serde_json::json!({
                "title": title,
                "path": path,
                "category": category
            }));
        }
    }
    Ok(books)
}
