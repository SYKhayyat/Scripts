use std::sync::Mutex;
use tauri::State;
use tantivy::collector::TopDocs;
use tantivy::query::QueryParser;
use tantivy::schema::*;
use tantivy::{Index, IndexWriter, ReloadPolicy};
use walkdir::WalkDir;
use std::fs;
use std::path::Path;

struct AppState {
    index: Index,
    schema: Schema,
}

fn rebuild_index(state: &AppState, library_path: &str) -> Result<(), String> {
    let mut writer: IndexWriter = state.index.writer(100_000_000).map_err(|e| e.to_string())?;

    let title_field = state.schema.get_field("title").unwrap();
    let body_field = state.schema.get_field("body").unwrap();

    writer.delete_all_documents().unwrap();

    for entry in WalkDir::new(library_path).into_iter().filter_map(|e| e.ok()) {
        if entry.path().extension().map_or(false, |ext| ext == "txt") {
            let title = entry.path().file_stem().unwrap().to_string_lossy().to_string();
            if let Ok(body) = fs::read_to_string(entry.path()) {
                writer.add_document(doc!(
                    title_field => title,
                    body_field => body
                )).unwrap();
            }
        }
    }

    writer.commit().map_err(|e| e.to_string())?;
    Ok(())
}

#[tauri::command]
fn rebuild_library(state: State<Mutex<AppState>>) -> Result<String, String> {
    let state = state.lock().unwrap();
    rebuild_index(&state, "./library").map(|_| "Library indexed successfully".to_string())
}

#[tauri::command]
fn search(query: String, state: State<Mutex<AppState>>) -> Result<Vec<serde_json::Value>, String> {
    let state = state.lock().unwrap();
    let reader = state.index.reader_builder()
        .reload_policy(ReloadPolicy::OnCommit)
        .try_into().map_err(|e| e.to_string())?;

    let searcher = reader.searcher();
    let title = state.schema.get_field("title").unwrap();
    let body = state.schema.get_field("body").unwrap();

    let query_parser = QueryParser::for_index(&state.index, vec![title, body]);
    let q = query_parser.parse_query(&query).map_err(|e| e.to_string())?;

    let top_docs = searcher.search(&q, &TopDocs::with_limit(50)).map_err(|e| e.to_string())?;

    let mut results = Vec::new();
    for (_, doc_address) in top_docs {
        let doc = searcher.doc(doc_address).map_err(|e| e.to_string())?;
        let title_val = doc.get_first(title).and_then(|v| v.as_text()).unwrap_or("");
        let body_val = doc.get_first(body).and_then(|v| v.as_text()).unwrap_or("");

        // Create short excerpt
        let excerpt = if body_val.len() > 180 {
            format!("{}...", &body_val[..180])
        } else {
            body_val.to_string()
        };

        results.push(serde_json::json!({
            "title": title_val,
            "excerpt": excerpt,
            "full_text": body_val
        }));
    }

    Ok(results)
}

fn main() {
    let mut schema_builder = Schema::builder();
    schema_builder.add_text_field("title", TEXT | STORED);
    schema_builder.add_text_field("body", TEXT | STORED);
    let schema = schema_builder.build();

    // Persistent index on disk
    let index = Index::create_in_dir("./data/index", schema.clone())
        .or_else(|_| Index::create_in_ram(schema.clone()))
        .unwrap();

    let state = Mutex::new(AppState { index, schema });

    tauri::Builder::default()
        .manage(state)
        .invoke_handler(tauri::generate_handler![search, rebuild_library])
        .run(tauri::generate_context!())
        .expect("error while running tauri application");
}
```

