<script lang="ts">
  import { invoke } from '@tauri-apps/api/tauri';
  import { onMount } from 'svelte';

  // UI State
  let activeSidebarTab = 'library';
  let query = '';
  let searchResults: any[] = [];
  let fontSize = 20;
  let lineHeight = 1.85;
  let isLoading = false;

  // Theme
  let currentTheme = 'system';

  // Panels
  let leftTabs: Array<{id: number; title: string; text: string; path: string; englishText?: string}> = [];
  let rightTabs: Array<{id: number; title: string; text: string; path: string; englishText?: string}> = [];
  let activeLeftId = 0;
  let activeRightId = 0;

  let leftReader: HTMLDivElement;
  let rightReader: HTMLDivElement;
  let isSyncing = false;

  // Bookmarks
  let bookmarks: Array<{title: string; leftTitle?: string; rightTitle?: string; timestamp: number}> = [];

  // Library
  let libraryTree: any = null;

  // Daily Learning
  let todayParashah = 'Bereishit';
  let todayDaf = 'Daf 2 (Berakhot)';

  const getActiveLeft = () => leftTabs.find(t => t.id === activeLeftId);
  const getActiveRight = () => rightTabs.find(t => t.id === activeRightId);

  // Render recursive tree
  function renderTree(node: any, level = 0): string {
    if (!node) return '';
    const indent = level * 12;
    let html = `<details style="margin-left: ${indent}px;" ${level === 0 ? 'open' : ''}>`;
    html += `<summary class="cursor-pointer py-1 text-sm ${node.path ? 'font-medium text-amber-200' : 'text-zinc-400'}">${node.name}</summary>`;

    if (node.children?.length) {
      html += node.children.map((child: any) =>
        child.path
          ? `<div class="pl-6 py-1 text-sm flex gap-3">
               <button onclick="openLeft('${child.path}', '${child.name}')" class="text-blue-400 hover:underline">Left</button>
               <button onclick="openRight('${child.path}', '${child.name}')" class="text-purple-400 hover:underline">Right</button>
             </div>`
          : renderTree(child, level + 1)
      ).join('');
    }
    html += '</details>';
    return html;
  }

  (window as any).openLeft = (path: string, title: string) => openInPanel(path, title, 'left');
  (window as any).openRight = (path: string, title: string) => openInPanel(path, title, 'right');

  // Theme
  function applyTheme(theme: string) {
    currentTheme = theme;
    const root = document.documentElement;
    root.classList.remove('light', 'dark');
    if (theme === 'system') {
      const isDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      root.classList.add(isDark ? 'dark' : 'light');
    } else {
      root.classList.add(theme);
    }
    localStorage.setItem('theme', theme);
  }

  // Daily Learning
  function updateDailyLearning() {
    const parashot = ["Bereishit", "Noach", "Lech Lecha", "Vayera", "Chayei Sarah", "Toldot", "Vayetzei", "Vayishlach", "Vayeshev", "Miketz", "Vayigash", "Vayechi"];
    const day = new Date().getDay();
    todayParashah = parashot[day % parashot.length];
    todayDaf = `Daf ${((Date.now() / 86400000) % 271 | 0) + 2} (Berakhot)`;
  }

  // Core Functions
  async function importLibrary() {
    isLoading = true;
    const msg = await invoke('import_official_library');
    alert(msg);
    await loadLibraryTree();
    isLoading = false;
  }

  async function rebuildLibrary() {
    isLoading = true;
    const msg = await invoke('rebuild_library');
    alert(msg);
    isLoading = false;
  }

  async function loadLibraryTree() {
    libraryTree = await invoke('get_library_tree');
  }

  async function openInPanel(path: string, title: string, side: 'left' | 'right') {
    try {
      const content = await invoke('load_book', { path });
      const newTab = { id: Date.now(), title, text: content, path, englishText: undefined };

      if (side === 'left') {
        leftTabs = [...leftTabs, newTab];
        activeLeftId = newTab.id;
      } else {
        rightTabs = [...rightTabs, newTab];
        activeRightId = newTab.id;
      }
      saveSession();
    } catch (e) {
      alert('Failed to open: ' + e);
    }
  }

  function closeTab(side: 'left' | 'right', id: number) {
    if (side === 'left') {
      leftTabs = leftTabs.filter(t => t.id !== id);
      if (leftTabs.length > 0 && activeLeftId === id) activeLeftId = leftTabs[leftTabs.length-1].id;
    } else {
      rightTabs = rightTabs.filter(t => t.id !== id);
      if (rightTabs.length > 0 && activeRightId === id) activeRightId = rightTabs[rightTabs.length-1].id;
    }
    saveSession();
  }

  function switchTab(side: 'left' | 'right', id: number) {
    if (side === 'left') activeLeftId = id;
    else activeRightId = id;
  }

  async function toggleEnglish(side: 'left' | 'right') {
    const tab = side === 'left' ? getActiveLeft() : getActiveRight();
    if (!tab) return;

    if (tab.englishText) {
      tab.englishText = undefined;
    } else {
      try {
        const normalized = await invoke('normalize_ref', { title: tab.title });
        const res = await fetch(`https://www.sefaria.org/api/v3/texts/${normalized}?context=0`);
        const data = await res.json();
        tab.englishText = data.text?.join('\n\n') || "No translation available.";
      } catch {
        tab.englishText = "Could not load English translation.";
      }
    }
    leftTabs = [...leftTabs];
    rightTabs = [...rightTabs];
  }

  function saveBookmark() {
    const left = getActiveLeft();
    const right = getActiveRight();
    if (!left && !right) return;

    bookmarks = [{
      title: left ? left.title : right!.title,
      leftTitle: left?.title,
      rightTitle: right?.title,
      timestamp: Date.now()
    }, ...bookmarks].slice(0, 30);

    activeSidebarTab = 'bookmarks';
    saveSession();
  }

  async function goToChapter(side: 'left' | 'right', direction: 'prev' | 'next') {
    const tab = side === 'left' ? getActiveLeft() : getActiveRight();
    if (!tab) return;

    const match = tab.title.match(/(\d+)$/);
    if (!match) return alert("Chapter navigation not available for this book.");

    const base = tab.title.replace(/\s+\d+$/, '');
    const num = parseInt(match[1]);
    const newNum = direction === 'next' ? num + 1 : num - 1;
    if (newNum < 1) return;

    const newTitle = `${base} ${newNum}`;
    const newPath = `./library/${newTitle}.txt`;

    try {
      await openInPanel(newPath, newTitle, side);
    } catch {
      alert(`Chapter ${newNum} not found.`);
    }
  }

  function printCurrent(side: 'left' | 'right') {
    const tab = side === 'left' ? getActiveLeft() : getActiveRight();
    if (!tab) return;

    const win = window.open('', '_blank');
    if (!win) return;
    win.document.write(`
      <html><head><title>${tab.title}</title>
      <style>body { font-family: "Noto Sans Hebrew", serif; padding: 40px; line-height: 1.9; direction: rtl; } .english { direction: ltr; margin-top: 50px; border-top: 2px solid #ddd; padding-top: 30px; }</style>
      </head><body>
        <h1>${tab.title}</h1>
        <div>${tab.text.replace(/\n/g, '<br><br>')}</div>
        ${tab.englishText ? `<div class="english">${tab.englishText.replace(/\n/g, '<br><br>')}</div>` : ''}
      </body></html>
    `);
    win.document.close();
    setTimeout(() => win.print(), 500);
  }

  function exportCurrent(side: 'left' | 'right') {
    const tab = side === 'left' ? getActiveLeft() : getActiveRight();
    if (!tab) return;
    const content = tab.englishText
      ? `# ${tab.title}\n\n**Hebrew:**\n${tab.text}\n\n**English:**\n${tab.englishText}`
      : `# ${tab.title}\n\n${tab.text}`;
    navigator.clipboard.writeText(content);
    alert('Exported to clipboard as Markdown');
  }

  function formatText(text: string, searchTerm: string, title: string): string {
    let html = text.replace(/(^|\n)(\d+|[א-ת]+)\.?\s+/gm, `$1<span class="verse-num" onclick="copyVerse('$2', '${title}')">$2</span> `);
    if (searchTerm) {
      const escaped = searchTerm.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
      html = html.replace(new RegExp(`(${escaped})`, 'gi'), '<mark class="highlight">$1</mark>');
    }
    return html;
  }

  function copyVerse(verse: string, title: string) {
    navigator.clipboard.writeText(`${title} ${verse}`);
  }

  function handleScroll(source: 'left' | 'right') {
    if (isSyncing) return;
    isSyncing = true;
    if (source === 'left' && rightReader) rightReader.scrollTop = leftReader.scrollTop;
    else if (source === 'right' && leftReader) leftReader.scrollTop = rightReader.scrollTop;
    setTimeout(() => isSyncing = false, 30);
  }

  function saveSession() {
    localStorage.setItem('leftTabs', JSON.stringify(leftTabs));
    localStorage.setItem('rightTabs', JSON.stringify(rightTabs));
    localStorage.setItem('bookmarks', JSON.stringify(bookmarks));
    localStorage.setItem('activeLeftId', activeLeftId.toString());
    localStorage.setItem('activeRightId', activeRightId.toString());
    localStorage.setItem('fontSize', fontSize.toString());
    localStorage.setItem('theme', currentTheme);
  }

  function loadSession() {
    const l = localStorage.getItem('leftTabs'); if (l) leftTabs = JSON.parse(l);
    const r = localStorage.getItem('rightTabs'); if (r) rightTabs = JSON.parse(r);
    const b = localStorage.getItem('bookmarks'); if (b) bookmarks = JSON.parse(b);
    activeLeftId = parseInt(localStorage.getItem('activeLeftId') || '0');
    activeRightId = parseInt(localStorage.getItem('activeRightId') || '0');
    fontSize = parseInt(localStorage.getItem('fontSize') || '20');
  }

  async function doSearch() {
    if (!query.trim()) return;
    searchResults = await invoke('search', { query });
    activeSidebarTab = 'search';
  }

  onMount(() => {
    const savedTheme = localStorage.getItem('theme') || 'system';
    applyTheme(savedTheme);
    loadSession();
    loadLibraryTree();
    updateDailyLearning();
  });
</script>

<div class="flex h-screen bg-zinc-950 text-zinc-100 overflow-hidden font-sans dark:bg-zinc-950">
  <!-- Sidebar -->
  <div class="w-80 border-r border-zinc-800 flex flex-col">
    <div class="p-4 border-b border-zinc-800">
      <h1 class="text-2xl font-bold text-amber-300">Otzaria Nix</h1>
      <div class="flex gap-2 mt-4">
        <button on:click={importLibrary} disabled={isLoading} class="flex-1 bg-violet-600 hover:bg-violet-500 py-3 rounded-2xl text-sm font-medium">
          {isLoading ? 'Importing...' : '📥 Import Library'}
        </button>
        <button on:click={rebuildLibrary} class="flex-1 bg-emerald-600 hover:bg-emerald-700 py-3 rounded-2xl text-sm font-medium">
          Rebuild Index
        </button>
      </div>
    </div>

    <div class="flex border-b border-zinc-800 text-sm">
      <button on:click={() => activeSidebarTab = 'library'} class="flex-1 py-3 {activeSidebarTab === 'library' ? 'border-b-2 border-amber-400 font-medium' : ''}">Library</button>
      <button on:click={() => activeSidebarTab = 'search'} class="flex-1 py-3 {activeSidebarTab === 'search' ? 'border-b-2 border-amber-400 font-medium' : ''}">Search</button>
      <button on:click={() => activeSidebarTab = 'daily'} class="flex-1 py-3 {activeSidebarTab === 'daily' ? 'border-b-2 border-amber-400 font-medium' : ''}">Daily</button>
      <button on:click={() => activeSidebarTab = 'bookmarks'} class="flex-1 py-3 {activeSidebarTab === 'bookmarks' ? 'border-b-2 border-amber-400 font-medium' : ''}">Bookmarks</button>
    </div>

    {#if activeSidebarTab === 'library'}
      <div class="flex-1 overflow-auto p-3 text-sm">
        {#if libraryTree}
          {@html renderTree(libraryTree)}
        {/if}
      </div>
    {:else if activeSidebarTab === 'search'}
      <div class="p-4">
        <input bind:value={query} on:keyup={(e) => e.key === 'Enter' && doSearch()} placeholder="Search texts..." class="w-full bg-zinc-900 border border-zinc-700 rounded-2xl px-5 py-3" />
        <button on:click={doSearch} class="mt-3 w-full bg-amber-600 py-3 rounded-2xl font-medium">Search</button>
      </div>
      <div class="flex-1 overflow-auto p-3">
        {#each searchResults as result}
          <div class="p-4 hover:bg-zinc-900 rounded-2xl mb-3 border border-zinc-800">
            <div class="font-medium">{result.title}</div>
            <div class="text-sm text-zinc-400 mt-1 line-clamp-3">{result.excerpt}</div>
            <div class="grid grid-cols-2 gap-2 mt-4">
              <button on:click={() => openInPanel(result.path || '', result.title, 'left')} class="py-2 bg-blue-900/60 hover:bg-blue-600 rounded-xl text-xs">Left</button>
              <button on:click={() => openInPanel(result.path || '', result.title, 'right')} class="py-2 bg-purple-900/60 hover:bg-purple-600 rounded-xl text-xs">Right</button>
            </div>
          </div>
        {/each}
      </div>
    {:else if activeSidebarTab === 'daily'}
      <div class="p-6">
        <h2 class="text-lg font-medium mb-4">Today's Learning</h2>
        <div class="bg-zinc-900 rounded-2xl p-5">
          <div class="text-amber-300 text-lg">Parashat {todayParashah}</div>
          <div class="text-zinc-400 mt-2">{todayDaf}</div>
        </div>
      </div>
    {:else if activeSidebarTab === 'bookmarks'}
      <div class="flex-1 overflow-auto p-3">
        <button on:click={saveBookmark} class="w-full mb-4 bg-amber-600 hover:bg-amber-500 py-3 rounded-2xl font-medium">⭐ Save Current View</button>
        {#each bookmarks as bm}
          <div on:click={() => alert('Reopening bookmarks coming soon')} class="p-4 hover:bg-zinc-900 rounded-2xl mb-3 cursor-pointer border border-zinc-800">
            <div class="font-medium">{bm.title}</div>
          </div>
        {/each}
      </div>
    {/if}
  </div>

  <!-- Left Panel -->
  <div class="flex-1 flex flex-col border-r border-zinc-800">
    <div class="h-12 bg-zinc-900 border-b border-zinc-800 flex overflow-x-auto">
      {#each leftTabs as tab (tab.id)}
        <div on:click={() => switchTab('left', tab.id)} class="px-5 py-2 border-r border-zinc-700 flex items-center gap-2 cursor-pointer hover:bg-zinc-800 {tab.id === activeLeftId ? 'bg-zinc-800' : ''}">
          <span class="truncate max-w-[160px]">{tab.title}</span>
          <button on:click|stopPropagation={() => closeTab('left', tab.id)} class="text-red-400">✕</button>
        </div>
      {/each}
    </div>

    {#if getActiveLeft()}
      {@const tab = getActiveLeft()}
      <div class="h-11 border-b border-zinc-800 px-6 flex items-center bg-zinc-950">
        <span class="font-medium truncate">{tab.title}</span>
        <button on:click={() => toggleEnglish('left')} class="ml-4 text-xs px-4 py-1 rounded-full {tab.englishText ? 'bg-emerald-600' : 'bg-zinc-700'}">English</button>
        <button on:click={() => goToChapter('left', 'prev')} class="ml-auto text-xs text-zinc-400">← Prev</button>
        <button on:click={() => goToChapter('left', 'next')} class="ml-2 text-xs text-zinc-400">Next →</button>
        <button on:click={() => printCurrent('left')} class="ml-4 text-xs text-blue-400">Print</button>
        <button on:click={() => exportCurrent('left')} class="ml-3 text-xs text-emerald-400">Export</button>
      </div>
      <div bind:this={leftReader} on:scroll={() => handleScroll('left')} class="flex-1 p-10 overflow-auto" dir="rtl" style="font-size: {fontSize}px; line-height: {lineHeight};">
        <div class="hebrew-text">
          {@html formatText(tab.text, query, tab.title)}
        </div>
        {#if tab.englishText}
          <div class="mt-12 pt-12 border-t border-zinc-700 text-zinc-300" style="font-size: {fontSize * 0.95}px;">
            {tab.englishText}
          </div>
        {/if}
      </div>
    {:else}
      <div class="flex-1 flex items-center justify-center text-zinc-500">Open a text on the left</div>
    {/if}
  </div>

  <!-- Right Panel (mirror) -->
  <div class="flex-1 flex flex-col">
    <div class="h-12 bg-zinc-900 border-b border-zinc-800 flex overflow-x-auto">
      {#each rightTabs as tab (tab.id)}
        <div on:click={() => switchTab('right', tab.id)} class="px-5 py-2 border-r border-zinc-700 flex items-center gap-2 cursor-pointer hover:bg-zinc-800 {tab.id === activeRightId ? 'bg-zinc-800' : ''}">
          <span class="truncate max-w-[160px]">{tab.title}</span>
          <button on:click|stopPropagation={() => closeTab('right', tab.id)} class="text-red-400">✕</button>
        </div>
      {/each}
    </div>

    {#if getActiveRight()}
      {@const tab = getActiveRight()}
      <div class="h-11 border-b border-zinc-800 px-6 flex items-center bg-zinc-950">
        <span class="font-medium truncate">{tab.title}</span>
        <button on:click={() => toggleEnglish('right')} class="ml-4 text-xs px-4 py-1 rounded-full {tab.englishText ? 'bg-emerald-600' : 'bg-zinc-700'}">English</button>
        <button on:click={() => goToChapter('right', 'prev')} class="ml-auto text-xs text-zinc-400">← Prev</button>
        <button on:click={() => goToChapter('right', 'next')} class="ml-2 text-xs text-zinc-400">Next →</button>
        <button on:click={() => printCurrent('right')} class="ml-4 text-xs text-blue-400">Print</button>
        <button on:click={() => exportCurrent('right')} class="ml-3 text-xs text-emerald-400">Export</button>
      </div>
      <div bind:this={rightReader} on:scroll={() => handleScroll('right')} class="flex-1 p-10 overflow-auto" dir="rtl" style="font-size: {fontSize}px; line-height: {lineHeight};">
        <div class="hebrew-text">
          {@html formatText(tab.text, query, tab.title)}
        </div>
        {#if tab.englishText}
          <div class="mt-12 pt-12 border-t border-zinc-700 text-zinc-300" style="font-size: {fontSize * 0.95}px;">
            {tab.englishText}
          </div>
        {/if}
      </div>
    {:else}
      <div class="flex-1 flex items-center justify-center text-zinc-500">Open a text on the right</div>
    {/if}
  </div>
</div>

<style>
  .hebrew-text {
    font-family: "Noto Sans Hebrew", system-ui, serif;
