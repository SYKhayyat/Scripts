    let citation = match format.as_str() {
        "traditional" => {
            // Traditional Talmudic citation
            format!("{}", text_title)
        },
        "academic" => {
            // Academic format
            if parts.len() >= 2 {
                format!("{} {}. Retrieved from Otzaria Digital Library.", parts[0], parts[1])
            } else {
                format!("{}. Retrieved from Otzaria Digital Library.", text_title)
            }
        },
        "bibtex" => {
            // BibTeX format
            let key = text_title.replace(" ", "_").to_lowercase();
            format!(
                "@misc{{{},\n  title={{{}}},\n  author={{Traditional}},\n  year={{n.d.}},\n  note={{Otzaria Digital Library}}\n}}",
                key, text_title
            )
        },
        _ => text_title.clone(),
    };

    Ok(citation)
}

