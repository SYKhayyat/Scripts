fn parse_verses(text: &str, notes: &HashMap<String, Vec<Note>>) -> Vec<Verse> {
    let lines: Vec<&str> = text.split('\n').filter(|l| !l.trim().is_empty()).collect();

    lines.iter().enumerate().map(|(i, line)| {
        let verse_id = format!("verse_{}", i);
        let verse_notes = notes.get(&verse_id).cloned().unwrap_or_default();
        let references = extract_references(line);

        Verse {
            number: (i + 1).to_string(),
            text: line.to_string(),
            references,
            notes: verse_notes,
        }
    }).collect()
}

fn extract_references(text: &str) -> Vec<String> {
    let mut refs = Vec::new();
    let books = vec!["Genesis", "Exodus", "Leviticus", "Numbers", "Deuteronomy",
                     "Bereishit", "Shemot", "Vayikra", "Bamidbar", "Devarim"];

    for book in books {
        if text.contains(book) {
            refs.push(format!("{} reference", book));
        }
    }

    refs
}

fn extract_english_translation(text: &str) -> String {
    text.lines()
        .filter(|l| !l.chars().any(|c| ('\u{0590}'..='\u{05FF}').contains(&c)))
        .collect::<Vec<_>>()
        .join("\n")
}

fn extract_keywords(text: &str) -> Vec<String> {
    let words: HashSet<String> = text
        .split_whitespace()
        .filter(|w| w.len() > 3)
        .map(|w| w.to_lowercase())
        .collect();

    words.into_iter().collect()
}

fn calculate_parsha(date: &str) -> String {
    let parshas = vec![
        "Bereishit", "Noach", "Lech Lecha", "Vayera", "Chayei Sarah",
        "Toldot", "Vayetzei", "Vayishlach", "Vayeshev", "Miketz",
    ];

    let week = chrono::Utc::now().iso_week().week() as usize;
    parshas[week % parshas.len()].to_string()
}

fn calculate_daf_yomi(date: &str) -> String {
    let cycle_start = chrono::NaiveDate::from_ymd_opt(2020, 9, 13).unwrap();
    let today = chrono::Utc::now().date_naive();
    let days = (today - cycle_start).num_days();
    let daf = (days % 2711) + 1;

    let tractates = vec!["Berachot", "Shabbat", "Eruvin", "Pesachim"];
    let tractate = tractates[(daf / 100) as usize % tractates.len()];
    let page = (daf % 100) + 2;

    format!("{} {}", tractate, page)
}

fn get_holidays(date: &str) -> Vec<String> {
    let month = chrono::Utc::now().month();
    match month {
        9 => vec!["Rosh Hashanah".to_string()],
        12 => vec!["Hanukkah".to_string()],
        _ => Vec::new(),
    }
}

