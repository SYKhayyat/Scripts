#[tauri::command]
fn analyze_text(text: String) -> Result<TextStatistics, String> {
    let verses: Vec<&str> = text.lines().filter(|l| !l.trim().is_empty()).collect();
    let words: Vec<&str> = text.split_whitespace().collect();
    let unique_words: HashSet<&str> = words.iter().copied().collect();

    let hebrew_words = words.iter()
        .filter(|w| w.chars().any(|c| ('\u{0590}'..='\u{05FF}').contains(&c)))
        .count();

    let english_words = words.len() - hebrew_words;

    let mut word_frequency: HashMap<String, u32> = HashMap::new();
    for word in &words {
        *word_frequency.entry(word.to_lowercase()).or_insert(0) += 1;
    }

    let mut freq_vec: Vec<_> = word_frequency.iter().collect();
    freq_vec.sort_by(|a, b| b.1.cmp(a.1));
    freq_vec.truncate(20);

    let top_frequency: HashMap<String, u32> = freq_vec.iter()
        .map(|(k, v)| (k.to_string(), **v))
        .collect();

    let avg_verse_length = if verses.len() > 0 {
        words.len() as f32 / verses.len() as f32
    } else {
        0.0
    };

    Ok(TextStatistics {
        total_words: words.len() as u32,
        total_verses: verses.len() as u32,
        unique_words: unique_words.len() as u32,
        hebrew_words: hebrew_words as u32,
        english_words: english_words as u32,
        word_frequency: top_frequency,
        average_verse_length: avg_verse_length,
    })
}

#[tauri::command]
fn compare_texts(
    text_titles: Vec<String>,
    state: State<Mutex<SearchEngine>>
) -> Result<ComparisonResult, String> {
    let engine = state.lock().unwrap();

    let reader = engine.index
        .reader_builder()
        .reload_policy(ReloadPolicy::OnCommit)
        .try_into()
        .map_err(|e| e.to_string())?;

    let searcher = reader.searcher();

    let title = engine.schema.get_field("title").unwrap();
    let body = engine.schema.get_field("body").unwrap();

    let query_parser = QueryParser::for_index(&engine.index, vec![title]);

    let mut texts = Vec::new();
    let mut all_words: Vec<HashSet<String>> = Vec::new();

    for text_title in text_titles {
        if let Ok(q) = query_parser.parse_query(&text_title) {
            if let Ok(top_docs) = searcher.search(&q, &TopDocs::with_limit(1)) {
                if let Some((_, doc_address)) = top_docs.first() {
                    if let Ok(doc) = searcher.doc(*doc_address) {
                        let title_text = doc.get_first(title)
                            .and_then(|v| v.as_text()).unwrap_or("");
                        let body_text = doc.get_first(body)
                            .and_then(|v| v.as_text()).unwrap_or("");

                        let words: HashSet<String> = body_text
                            .split_whitespace()
                            .map(|w| normalize_hebrew(w).to_lowercase())
                            .filter(|w| w.len() > 2)
                            .collect();

                        all_words.push(words.clone());

                        texts.push(ComparisonText {
                            title: title_text.to_string(),
                            body: body_text.to_string(),
                            highlights: Vec::new(),
                        });
                    }
                }
            }
        }
    }

    let mut common_words = if let Some(first) = all_words.first() {
        first.clone()
    } else {
        HashSet::new()
    };

    for words in all_words.iter().skip(1) {
        common_words = common_words.intersection(words).cloned().collect();
    }

    let common_themes: Vec<String> = common_words.into_iter()
        .take(10)
        .collect();

    Ok(ComparisonResult {
        texts,
        common_themes,
    })
}

