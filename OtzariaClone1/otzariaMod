```rust
use std::sync::Mutex;
use tauri::State;
use tantivy::collector::TopDocs;
use tantivy::query::QueryParser;
use tantivy::schema::*;
use tantivy::{Index, ReloadPolicy};
use serde::{Deserialize, Serialize};

#[derive(Serialize, Deserialize)]
struct SearchResult {
    title: String,
    body: String,
    score: f32,
}

struct SearchEngine {
    index: Index,
    schema: Schema,
}

fn init_search_engine() -> SearchEngine {
    let mut schema_builder = Schema::builder();
    schema_builder.add_text_field("title", TEXT | STORED);
    schema_builder.add_text_field("body", TEXT | STORED);
    schema_builder.add_text_field("book", STRING | STORED);

    let schema = schema_builder.build();
    let index = Index::create_in_ram(schema.clone());

    let mut index_writer = index.writer(50_000_000).unwrap();

    let title = schema.get_field("title").unwrap();
    let body = schema.get_field("body").unwrap();
    let book = schema.get_field("book").unwrap();

    // Sample Torah texts
    let texts = vec![
        ("Torah", "Bereishit 1:1", "בְּרֵאשִׁית בָּרָא אֱלֹהִים אֵת הַשָּׁמַיִם וְאֵת הָאָרֶץ - In the beginning God created the heaven and the earth."),
        ("Torah", "Bereishit 1:3", "וַיֹּאמֶר אֱלֹהִים יְהִי אוֹר וַיְהִי אוֹר - And God said, Let there be light: and there was light."),
        ("Torah", "Bereishit 1:27", "וַיִּבְרָא אֱלֹהִים אֶת הָאָדָם בְּצַלְמוֹ - So God created man in his own image."),
        ("Torah", "Shemot 20:2", "אָנֹכִי ה' אֱלֹהֶיךָ - I am the LORD your God, who brought you out of Egypt."),
        ("Talmud", "Pirkei Avot 1:1", "משֶׁה קִבֵּל תּוֹרָה מִסִּינַי - Moses received the Torah from Sinai."),
        ("Talmud", "Pirkei Avot 1:2", "עַל שְׁלשָׁה דְבָרִים הָעוֹלָם עוֹמֵד - The world stands on three things: Torah, service, and acts of kindness."),
        ("Talmud", "Pirkei Avot 1:14", "אִם אֵין אֲנִי לִי מִי לִי - If I am not for myself, who will be for me?"),
        ("Mishna", "Berachot 1:1", "מֵאֵימָתַי קוֹרִין אֶת שְׁמַע בָּעֲרָבִין - From what time may one recite the Shema in the evening?"),
    ];

    for (book_name, verse_title, verse_body) in texts {
        index_writer.add_document(doc!(
            book => book_name,
            title => verse_title,
            body => verse_body
        )).unwrap();
    }

    index_writer.commit().unwrap();

    SearchEngine { index, schema }
}

#[tauri::command]
fn search_text(query: String, state: State<Mutex<SearchEngine>>) -> Result<Vec<SearchResult>, String> {
    let engine = state.lock().unwrap();

    let reader = engine.index
        .reader_builder()
        .reload_policy(ReloadPolicy::OnCommit)
        .try_into()
        .map_err(|e| e.to_string())?;

    let searcher = reader.searcher();

    let title = engine.schema.get_field("title").unwrap();
    let body = engine.schema.get_field("body").unwrap();
    let book = engine.schema.get_field("book").unwrap();

    let query_parser = QueryParser::for_index(&engine.index, vec![title, body, book]);
    let q = query_parser.parse_query(&query).map_err(|e| e.to_string())?;
    let top_docs = searcher.search(&q, &TopDocs::with_limit(20)).map_err(|e| e.to_string())?;

    let mut results = Vec::new();
    for (score, doc_address) in top_docs {
        let retrieved_doc = searcher.doc(doc_address).map_err(|e| e.to_string())?;

        let result_title = retrieved_doc.get_first(title)
            .and_then(|v| v.as_text()).unwrap_or("").to_string();
        let result_body = retrieved_doc.get_first(body)
            .and_then(|v| v.as_text()).unwrap_or("").to_string();

        results.push(SearchResult {
            title: result_title,
            body: result_body,
            score,
        });
    }

    Ok(results)
}

#[tauri::command]
fn get_all_books(state: State<Mutex<SearchEngine>>) -> Result<Vec<String>, String> {
    Ok(vec![
        "Torah".to_string(),
        "Talmud".to_string(),
        "Mishna".to_string(),
    ])
}

fn main() {
    let engine = Mutex::new(init_search_engine());

    tauri::Builder::default()
        .manage(engine)
        .invoke_handler(tauri::generate_handler![search_text, get_all_books])
        .run(tauri::generate_context!())
        .expect("error while running tauri application");
}
