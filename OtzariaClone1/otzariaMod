#[tauri::command]
fn find_related_texts(
    text_title: String,
    state: State<Mutex<SearchEngine>>
) -> Result<Vec<RelatedText>, String> {
    let engine = state.lock().unwrap();

    let reader = engine.index
        .reader_builder()
        .reload_policy(ReloadPolicy::OnCommit)
        .try_into()
        .map_err(|e| e.to_string())?;

    let searcher = reader.searcher();

    let title = engine.schema.get_field("title").unwrap();
    let body = engine.schema.get_field("body").unwrap();
    let book = engine.schema.get_field("book").unwrap();

    let query_parser = QueryParser::for_index(&engine.index, vec![title]);
    let q = query_parser.parse_query(&text_title).map_err(|e| e.to_string())?;
    let top_docs = searcher.search(&q, &TopDocs::with_limit(1)).map_err(|e| e.to_string())?;

    if top_docs.is_empty() {
        return Ok(Vec::new());
    }

    let (_, doc_address) = top_docs[0];
    let source_doc = searcher.doc(doc_address).map_err(|e| e.to_string())?;
    let source_text = source_doc.get_first(body).and_then(|v| v.as_text()).unwrap_or("");
    let source_book = source_doc.get_first(book).and_then(|v| v.as_text()).unwrap_or("");

    let keywords = extract_keywords(source_text);
    let mut related = Vec::new();

    for keyword in keywords.iter().take(5) {
        let kw_query = query_parser.parse_query(keyword).ok();
        if let Some(q) = kw_query {
            if let Ok(docs) = searcher.search(&q, &TopDocs::with_limit(3)) {
                for (score, addr) in docs {
                    if let Ok(doc) = searcher.doc(addr) {
                        if let Some(t) = doc.get_first(title).and_then(|v| v.as_text()) {
                            if t != text_title {
                                related.push(RelatedText {
                                    title: t.to_string(),
                                    similarity_score: score,
                                    reason: format!("Related by keyword: {}", keyword),
                                });
                            }
                        }
                    }
                }
            }
        }
    }

    related.sort_by(|a, b| b.similarity_score.partial_cmp(&a.similarity_score).unwrap());
    related.truncate(10);

    Ok(related)
}

