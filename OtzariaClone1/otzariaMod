// Hebrew text normalization - removes nikud (vowel points) and taamim (cantillation marks)
fn normalize_hebrew(text: &str) -> String {
    text.chars()
        .filter(|c| {
            let ch = *c as u32;
            // Remove nikud (0x0591-0x05C7) and other marks
            !(ch >= 0x0591 && ch <= 0x05C7 ||
              ch >= 0x05A0 && ch <= 0x05AF ||
              ch >= 0x05C8 && ch <= 0x05CF ||
              ch == 0x05BD || ch == 0x05BF || ch == 0x05C0)
        })
        .collect()
}

fn init_search_engine() -> SearchEngine {
    let mut schema_builder = Schema::builder();
    schema_builder.add_text_field("title", TEXT | STORED);
    schema_builder.add_text_field("body", TEXT | STORED);
    schema_builder.add_text_field("body_normalized", TEXT); // For Hebrew search
    schema_builder.add_text_field("book", STRING | STORED);
    schema_builder.add_text_field("category", STRING | STORED);
    schema_builder.add_text_field("type", STRING | STORED); // "text" or "commentary"

