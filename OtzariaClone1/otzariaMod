class FlashcardManager {
    async createFlashcard(front, back, source) {
        try {
            const card = await invoke('create_flashcard', { front, back, source });
            showToast('Flashcard created!');
            return card;
        } catch (error) {
            showToast('Error creating flashcard: ' + error, 3000);
        }
    }

    async startReview() {
        try {
            const dueCards = await invoke('get_due_flashcards');

            if (dueCards.length === 0) {
                showToast('No cards due for review!');
                return;
            }

            this.reviewSession(dueCards, 0);
        } catch (error) {
            showToast('Error: ' + error, 3000);
        }
    }

    reviewSession(cards, index) {
        if (index >= cards.length) {
            showToast('Review complete! 🎉');
            return;
        }

        const card = cards[index];
        const dialog = document.createElement('div');
        dialog.className = 'flashcard-review-dialog modal active';
        dialog.innerHTML = `
            <div class="modal-content">
                <div class="modal-header">
                    <h2>🗂️ Flashcard Review (${index + 1}/${cards.length})</h2>
                    <button class="modal-close">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="flashcard">
                        <div class="flashcard-front">${escapeHtml(card.front)}</div>
                        <div class="flashcard-back" style="display: none;">${escapeHtml(card.back)}</div>
                        <button id="flipCard" class="action-btn">Flip Card</button>
                    </div>
                    <div class="flashcard-rating" style="display: none;">
                        <p>How well did you know this?</p>
                        <div class="rating-buttons">
                            <button data-quality="1">😰 Again</button>
                            <button data-quality="3">😐 Hard</button>
                            <button data-quality="4">🙂 Good</button>
                            <button data-quality="5">😄 Easy</button>
                        </div>
                    </div>
                    <div class="flashcard-source">${escapeHtml(card.source)}</div>
                </div>
            </div>
        `;

        document.body.appendChild(dialog);

        const front = dialog.querySelector('.flashcard-front');
        const back = dialog.querySelector('.flashcard-back');
        const flipBtn = dialog.getElementById('flipCard');
        const rating = dialog.querySelector('.flashcard-rating');

        flipBtn.onclick = () => {
            front.style.display = 'none';
            back.style.display = 'block';
            flipBtn.style.display = 'none';
            rating.style.display = 'block';
        };

        dialog.querySelector('.modal-close').onclick = () => dialog.remove();

        dialog.querySelectorAll('.rating-buttons button').forEach(btn => {
            btn.onclick = async () => {
                const quality = parseInt(btn.dataset.quality);
                await invoke('review_flashcard', { cardId: card.id, quality });
                dialog.remove();
                this.reviewSession(cards, index + 1);
            };
        });
    }

    showCreateFromText(text, source) {
        const dialog = document.createElement('div');
        dialog.className = 'create-flashcard-dialog modal active';
        dialog.innerHTML = `
            <div class="modal-content">
                <div class="modal-header">
                    <h2>🗂️ Create Flashcard</h2>
                    <button class="modal-close">&times;</button>
                </div>
                <div class="modal-body">
                    <label>Front (Question):</label>
                    <textarea id="cardFront" rows="3"></textarea>
                    <label>Back (Answer):</label>
                    <textarea id="cardBack" rows="3">${escapeHtml(text)}</textarea>
                    <label>Source:</label>
                    <input type="text" id="cardSource" value="${escapeHtml(source)}" />
                    <button class="action-btn" id="createCardBtn">Create Flashcard</button>
                </div>
            </div>
        `;

        document.body.appendChild(dialog);

        dialog.querySelector('.modal-close').onclick = () => dialog.remove();
        document.getElementById('createCardBtn').onclick = async () => {
            const front = document.getElementById('cardFront').value;
            const back = document.getElementById('cardBack').value;
            const src = document.getElementById('cardSource').value;

            if (front && back) {
                await this.createFlashcard(front, back, src);
                dialog.remove();
            }
        };
    }
}

// ========== FOCUS MODE ==========
class FocusMode {
    enable() {
        document.body.classList.add('focus-mode');
        document.querySelector('.sidebar')?.classList.add('hidden');
        document.querySelector('.toolbar')?.classList.add('minimal');
        document.querySelector('.advanced-toolbar')?.classList.add('hidden');
        showToast('Focus mode enabled (Esc to exit)');
    }

    disable() {
        document.body.classList.remove('focus-mode');
        document.querySelector('.sidebar')?.classList.remove('hidden');
        document.querySelector('.toolbar')?.classList.remove('minimal');
        document.querySelector('.advanced-toolbar')?.classList.remove('hidden');
        showToast('Focus mode disabled');
    }

    toggle() {
        if (document.body.classList.contains('focus-mode')) {
            this.disable();
        } else {
            this.enable();
        }
    }
}

