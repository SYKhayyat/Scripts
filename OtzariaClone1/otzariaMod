// ========== MULTI-PANE LAYOUT MANAGER ==========
class MultiPaneManager {
    constructor() {
        this.paneCount = 2;
        this.panes = [];
    }

    setPaneCount(count) {
        if (count < 1 || count > 4) return;

        this.paneCount = count;
        this.rebuildPanes();
    }

    rebuildPanes() {
        const container = document.querySelector('.panes');
        if (!container) return;

        container.innerHTML = '';
        this.panes = [];

        for (let i = 0; i < this.paneCount; i++) {
            const pane = document.createElement('div');
            pane.className = 'pane';
            pane.id = `pane_${i}`;
            pane.innerHTML = `
                <div class="pane-header">
                    <h3>Pane ${i + 1}</h3>
                    <button class="pane-close" data-pane="${i}">×</button>
                </div>
                <div class="pane-content" id="pane_content_${i}">
                    <p class="empty-state">No content loaded</p>
                </div>
            `;

            container.appendChild(pane);
            this.panes.push(pane);

            if (i < this.paneCount - 1) {
                const divider = document.createElement('div');
                divider.className = 'pane-divider';
                container.appendChild(divider);
            }
        }

        this.applyLayout();
        this.setupPaneEvents();
    }

    applyLayout() {
        const flexBasis = `${100 / this.paneCount}%`;
        this.panes.forEach(pane => {
            pane.style.flex = `1 1 ${flexBasis}`;
        });
    }

    setupPaneEvents() {
        document.querySelectorAll('.pane-close').forEach(btn => {
            btn.onclick = () => {
                if (this.paneCount > 1) {
                    this.setPaneCount(this.paneCount - 1);
                }
            };
        });
    }

    loadTextInPane(paneIndex, text) {
        const content = document.getElementById(`pane_content_${paneIndex}`);
        if (content) {
            content.innerHTML = formatText(text.body);
            content.className = 'pane-content hebrew';
        }
    }

    showLayoutSelector() {
        const dialog = document.createElement('div');
        dialog.className = 'layout-selector-dialog modal active';
