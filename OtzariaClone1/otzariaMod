// ========== TEXT-TO-SPEECH ==========
class TextToSpeech {
    constructor() {
        this.synth = window.speechSynthesis;
        this.speaking = false;
    }

    speak(text, lang = 'he-IL') {
        if (this.speaking) {
            this.stop();
            return;
        }

        const utterance = new SpeechSynthesisUtterance(text);
        utterance.lang = lang;
        utterance.rate = 0.8;

        utterance.onend = () => {
            this.speaking = false;
            this.updateButton();
        };

        this.synth.speak(utterance);
        this.speaking = true;
        this.updateButton();
    }

    stop() {
        this.synth.cancel();
        this.speaking = false;
        this.updateButton();
    }

    updateButton() {
        const btn = document.getElementById('ttsBtn');
        if (btn) {
            btn.textContent = this.speaking ? '⏸️' : '🔊';
            btn.title = this.speaking ? 'Stop reading' : 'Read aloud';
        }
    }

    speakCurrentText() {
        if (!currentText) return;

        const hebrewText = currentText.body.split('\n\n')[0]; // Get Hebrew part
        this.speak(hebrewText);
    }
}

