#[tauri::command]
fn review_flashcard(
    card_id: String,
    quality: u8,
    state: State<Mutex<SearchEngine>>
) -> Result<Flashcard, String> {
    let mut engine = state.lock().unwrap();

    if let Some(card) = engine.flashcards.iter_mut().find(|c| c.id == card_id) {
        let quality = quality as f32;

        if quality >= 3.0 {
            card.ease_factor = card.ease_factor + (0.1 - (5.0 - quality) * (0.08 + (5.0 - quality) * 0.02));
            card.ease_factor = card.ease_factor.max(1.3);

            if card.last_reviewed.is_none() {
                card.interval_days = 1;
            } else {
                card.interval_days = (card.interval_days as f32 * card.ease_factor).round() as u32;
            }
        } else {
            card.interval_days = 1;
        }

        card.last_reviewed = Some(chrono::Utc::now().timestamp());

        save_flashcards(&engine.flashcards);
        Ok(card.clone())
    } else {
        Err("Flashcard not found".to_string())
    }
}

