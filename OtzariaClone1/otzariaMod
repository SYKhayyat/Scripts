#!/usr/bin/env python3
"""
Download Torah texts from Sefaria API and save them in the library folder.
"""

import requests
import json
import os
import time
from pathlib import Path

# Base URL for Sefaria API
SEFARIA_API = "https://www.sefaria.org/api"

# Library structure
LIBRARY_PATH = "./library"

def download_index():
    """Get the full index of available texts from Sefaria."""
    print("Downloading Sefaria index...")
    response = requests.get(f"{SEFARIA_API}/index/")
    return response.json()

def download_text(book_title, category="Torah"):
    """Download a specific book from Sefaria."""
    print(f"Downloading {book_title}...")

    # Create category directory
    category_dir = Path(LIBRARY_PATH) / category
    category_dir.mkdir(parents=True, exist_ok=True)

    # Get the text
    url = f"{SEFARIA_API}/texts/{book_title}"
    response = requests.get(url)

    if response.status_code != 200:
        print(f"  ✗ Failed to download {book_title}")
        return False

    data = response.json()

    # Extract the text content
    if "text" not in data:
        print(f"  ✗ No text found for {book_title}")
        return False

    # Create book directory
    book_dir = category_dir / book_title.replace(" ", "_")
    book_dir.mkdir(exist_ok=True)

    # Handle different text structures
    text_content = data["text"]

    if isinstance(text_content, list):
        # Multi-chapter book
        for idx, chapter in enumerate(text_content, 1):
            if isinstance(chapter, list):
                # Verses in chapter
                chapter_text = "\n\n".join([
                    f"{verse}"
                    for verse_idx, verse in enumerate(chapter, 1)
                    if verse
                ])
            else:
                chapter_text = chapter

            if chapter_text.strip():
                file_path = book_dir / f"chapter_{idx}.txt"
                with open(file_path, "w", encoding="utf-8") as f:
                    f.write(chapter_text)

        print(f"  ✓ Saved {len(text_content)} chapters")
    else:
        # Single text
        file_path = book_dir / f"{book_title.replace(' ', '_')}.txt"
        with open(file_path, "w", encoding="utf-8") as f:
            f.write(text_content)
        print(f"  ✓ Saved single text")

    return True

def download_torah():
    """Download the five books of Torah."""
    torah_books = [
        "Genesis",
        "Exodus",
        "Leviticus",
        "Numbers",
        "Deuteronomy"
    ]

    for book in torah_books:
        download_text(book, "Torah")
        time.sleep(1)  # Be polite to the API

def download_talmud_sample():
    """Download a sample of Talmud tractates."""
    tractates = [
        "Berakhot",
        "Shabbat",
        "Eruvin",
        "Pesachim"
    ]

    for tractate in tractates:
        download_text(f"Mishnah_{tractate}", "Mishna")
        time.sleep(1)

def download_pirkei_avot():
    """Download Pirkei Avot (Ethics of the Fathers)."""
    download_text("Pirkei_Avot", "Talmud")
    time.sleep(1)

def download_commentary():
    """Download sample commentaries."""
    commentaries = [
        ("Rashi_on_Genesis", "Commentary"),
        ("Rashi_on_Exodus", "Commentary"),
    ]

    for comm, category in commentaries:
        download_text(comm, category)
        time.sleep(1)

def download_essential_library():
    """Download a curated set of essential texts."""
    print("=" * 60)
    print("Downloading Essential Jewish Library from Sefaria")
    print("=" * 60)

    # Create library directory
    Path(LIBRARY_PATH).mkdir(exist_ok=True)

    # Download core texts
    print("\n[1/4] Downloading Torah...")
    download_torah()

    print("\n[2/4] Downloading Pirkei Avot...")
    download_pirkei_avot()

    print("\n[3/4] Downloading Sample Mishna...")
    download_talmud_sample()

    print("\n[4/4] Downloading Commentary...")
    download_commentary()

    print("\n" + "=" * 60)
    print("Download complete! Library saved to:", LIBRARY_PATH)
    print("Run your app and it will automatically index these texts.")
    print("=" * 60)

def download_custom_text(title, category):
    """Download a specific text by title."""
    return download_text(title, category)

if __name__ == "__main__":
    import sys

    if len(sys.argv) > 1:
        # Download specific text
        if len(sys.argv) >= 3:
            title = sys.argv[1]
            category = sys.argv[2]
            download_custom_text(title, category)
        else:
            print("Usage: python3 download_library.py [text_title] [category]")
            print("   or: python3 download_library.py  (downloads essential library)")
    else:
        # Download essential library
        download_essential_library()

