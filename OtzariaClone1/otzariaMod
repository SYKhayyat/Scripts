    }

    async renderHighlights(verseId) {
        try {
            const highlights = await invoke('get_highlights', { verseId });
            const verse = document.querySelector(`[data-verse="${verseId}"]`);

            if (!verse) return;

            const textEl = verse.querySelector('.verse-text');
            if (!textEl) return;

            const originalText = textEl.dataset.originalText || textEl.textContent;
            textEl.dataset.originalText = originalText;

            highlights.sort((a, b) => a.start - b.start);

            let html = '';
            let lastIndex = 0;

            for (const hl of highlights) {
                html += escapeHtml(originalText.substring(lastIndex, hl.start));
                html += `<mark class="highlight" style="background-color: ${hl.color}" data-highlight-id="${hl.id}" title="${hl.note || 'Highlight'}">`;
                html += escapeHtml(originalText.substring(hl.start, hl.end));
                html += '</mark>';
                lastIndex = hl.end;
            }
            html += escapeHtml(originalText.substring(lastIndex));

            textEl.innerHTML = html;

            textEl.querySelectorAll('.highlight').forEach(mark => {
                mark.addEventListener('contextmenu', (e) => {
                    e.preventDefault();
                    const hlId = mark.dataset.highlightId;
                    this.showHighlightMenu(e.clientX, e.clientY, hlId, verseId);
                });
            });

        } catch (error) {
            console.error('Error rendering highlights:', error);
        }
    }

    showHighlightMenu(x, y, highlightId, verseId) {
        const menu = document.createElement('div');
        menu.className = 'context-menu';
        menu.style.left = x + 'px';
        menu.style.top = y + 'px';
        menu.innerHTML = `
            <div class="context-menu-item">📝 Add Note</div>
            <div class="context-menu-item">🗑️ Remove Highlight</div>
        `;

        document.body.appendChild(menu);

        menu.children[0].onclick = () => {
            const note = prompt('Add a note to this highlight:');
            if (note) {
                // Would need update_highlight command
            }
            menu.remove();
        };

        menu.children[1].onclick = async () => {
            await invoke('delete_highlight', { highlightId });
            await this.renderHighlights(verseId);
            menu.remove();
        };

        setTimeout(() => {
            document.addEventListener('click', () => menu.remove(), { once: true });
        }, 100);
    }

    async renderAllHighlights() {
        const verses = document.querySelectorAll('.verse-block');
        for (const verse of verses) {
            const verseId = verse.dataset.verse;
            await this.renderHighlights(verseId);
        }
    }

    showColorPicker() {
        const picker = document.createElement('div');
        picker.className = 'color-picker-dialog modal active';
        picker.innerHTML = `
            <div class="modal-content">
                <div class="modal-header">
                    <h2>🎨 Choose Highlight Color</h2>
                    <button class="modal-close">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="color-grid">
                        ${this.colors.map(color => `
                            <div class="color-option" style="background: ${color}" data-color="${color}"></div>
                        `).join('')}
                    </div>
                </div>
            </div>
        `;

        document.body.appendChild(picker);

        picker.querySelector('.modal-close').onclick = () => picker.remove();
        picker.querySelectorAll('.color-option').forEach(opt => {
            opt.onclick = () => {
