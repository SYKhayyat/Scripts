#[tauri::command]
fn analyze_text(text: String) -> Result<TextStatistics, String> {
    let verses: Vec<&str> = text.lines().filter(|l| !l.trim().is_empty()).collect();

    let words: Vec<&str> = text.split_whitespace().collect();
    let unique_words: HashSet<&str> = words.iter().copied().collect();

    let hebrew_words = words.iter()
        .filter(|w| w.chars().any(|c| ('\u{0590}'..='\u{05FF}').contains(&c)))
        .count();

    let english_words = words.len() - hebrew_words;

    let mut word_frequency: HashMap<String, u32> = HashMap::new();
    for word in &words {
        *word_frequency.entry(word.to_lowercase()).or_insert(0) += 1;
    }

    // Get top 20 most frequent words
    let mut freq_vec: Vec<_> = word_frequency.iter().collect();
    freq_vec.sort_by(|a, b| b.1.cmp(a.1));
    freq_vec.truncate(20);

    let top_frequency: HashMap<String, u32> = freq_vec.iter()
        .map(|(k, v)| (k.to_string(), **v))
        .collect();

    let avg_verse_length = if verses.len() > 0 {
        words.len() as f32 / verses.len() as f32
    } else {
        0.0
    };

    Ok(TextStatistics {
        total_words: words.len() as u32,
        total_verses: verses.len() as u32,
        unique_words: unique_words.len() as u32,
        hebrew_words: hebrew_words as u32,
        english_words: english_words as u32,
        word_frequency: top_frequency,
        average_verse_length: avg_verse_length,
    })
}

