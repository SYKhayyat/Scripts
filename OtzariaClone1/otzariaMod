// ========== AUTO-SCROLL READER ==========
class AutoScroll {
    constructor() {
        this.scrolling = false;
        this.speed = 1; // pixels per frame
        this.interval = null;
    }

    start(speed = 1) {
        if (this.scrolling) {
            this.stop();
            return;
        }

        this.speed = speed;
        this.scrolling = true;

        const content = document.querySelector('.pane-content');
        if (!content) return;

        this.interval = setInterval(() => {
            content.scrollTop += this.speed;

            // Stop at bottom
            if (content.scrollTop >= content.scrollHeight - content.clientHeight) {
                this.stop();
            }
        }, 16); // ~60fps

        showToast('Auto-scroll started (click to stop)');
        this.showControls();
    }

    stop() {
        this.scrolling = false;
        if (this.interval) {
            clearInterval(this.interval);
            this.interval = null;
        }
        document.querySelector('.autoscroll-controls')?.remove();
        showToast('Auto-scroll stopped');
    }

    showControls() {
        const controls = document.createElement('div');
        controls.className = 'autoscroll-controls';
        controls.innerHTML = `
            <button onclick="autoScroll.adjustSpeed(-0.5)">−</button>
            <span>Speed: ${this.speed.toFixed(1)}x</span>
            <button onclick="autoScroll.adjustSpeed(0.5)">+</button>
            <button onclick="autoScroll.stop()">⏹️</button>
        `;

        document.body.appendChild(controls);
    }

    adjustSpeed(delta) {
        this.speed = Math.max(0.5, Math.min(5, this.speed + delta));
        const speedDisplay = document.querySelector('.autoscroll-controls span');
        if (speedDisplay) {
            speedDisplay.textContent = `Speed: ${this.speed.toFixed(1)}x`;
        }
    }
}

