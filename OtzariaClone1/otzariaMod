fn load_texts_from_folder(index_writer: &mut tantivy::IndexWriter, schema: &Schema, folder: &str) {
    let title_field = schema.get_field("title").unwrap();
    let body_field = schema.get_field("body").unwrap();
    let book_field = schema.get_field("book").unwrap();

