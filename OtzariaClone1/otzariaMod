class ProgressTracker {
    constructor() {
        this.currentProgress = 0;
        this.autoSave = true;
    }

    trackScroll() {
        const content = document.querySelector('.pane-content');
        if (!content || !currentText) return;

        const scrollPercentage = (content.scrollTop / (content.scrollHeight - content.clientHeight)) * 100;
        this.currentProgress = scrollPercentage;

        // Find current verse
        const verses = content.querySelectorAll('.verse-block');
        let currentVerse = '';

        verses.forEach(verse => {
            const rect = verse.getBoundingClientRect();
            if (rect.top >= 0 && rect.top <= window.innerHeight / 2) {
                currentVerse = verse.dataset.verse;
            }
        });

        if (this.autoSave && scrollPercentage > 0) {
            this.saveProgress(currentText.title, currentVerse, scrollPercentage);
        }
    }

    async saveProgress(textId, verseId, percentage) {
        try {
            await invoke('save_progress', { textId, verseId, percentage });
        } catch (error) {
            console.error('Error saving progress:', error);
        }
    }

    async loadProgress(textId) {
