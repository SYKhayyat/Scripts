#[tauri::command]
fn compare_texts(
    text_titles: Vec<String>,
    state: State<Mutex<SearchEngine>>
) -> Result<ComparisonResult, String> {
    let engine = state.lock().unwrap();

    let reader = engine.index
        .reader_builder()
        .reload_policy(ReloadPolicy::OnCommit)
        .try_into()
        .map_err(|e| e.to_string())?;

    let searcher = reader.searcher();

    let title = engine.schema.get_field("title").unwrap();
    let body = engine.schema.get_field("body").unwrap();

    let query_parser = QueryParser::for_index(&engine.index, vec![title]);

    let mut texts = Vec::new();
    let mut all_words: Vec<HashSet<String>> = Vec::new();

    for text_title in text_titles {
        if let Ok(q) = query_parser.parse_query(&text_title) {
            if let Ok(top_docs) = searcher.search(&q, &TopDocs::with_limit(1)) {
                if let Some((_, doc_address)) = top_docs.first() {
                    if let Ok(doc) = searcher.doc(*doc_address) {
                        let title_text = doc.get_first(title)
                            .and_then(|v| v.as_text()).unwrap_or("");
                        let body_text = doc.get_first(body)
                            .and_then(|v| v.as_text()).unwrap_or("");

                        // Extract words for comparison
                        let words: HashSet<String> = body_text
                            .split_whitespace()
                            .map(|w| normalize_hebrew(w).to_lowercase())
                            .filter(|w| w.len() > 2)
                            .collect();

                        all_words.push(words.clone());

                        texts.push(ComparisonText {
                            title: title_text.to_string(),
                            body: body_text.to_string(),
                            highlights: Vec::new(),
                        });
                    }
                }
            }
        }
    }

    // Find common words across all texts
    let mut common_words = if let Some(first) = all_words.first() {
        first.clone()
    } else {
        HashSet::new()
    };

    for words in all_words.iter().skip(1) {
        common_words = common_words.intersection(words).cloned().collect();
    }

    let common_themes: Vec<String> = common_words.into_iter()
        .take(10)
        .collect();

    Ok(ComparisonResult {
        texts,
        common_themes,
    })
}

