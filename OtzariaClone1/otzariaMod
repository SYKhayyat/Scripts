// Load complete features
const completeScript = document.createElement('script');
completeScript.src = 'complete-features.js';
document.head.appendChild(completeScript);

setTimeout(() => {
    setupCompleteFeatures();
}, 600);

function setupCompleteFeatures() {
    // Highlight button
    document.getElementById('highlightBtn')?.addEventListener('click', () => {
        highlightManager.showColorPicker();
    });

    // Text selection highlighting
    document.addEventListener('mouseup', async () => {
        if (!highlightManager.highlightMode) return;

        const selection = window.getSelection();
        if (!selection.toString().trim()) return;

        const range = selection.getRangeAt(0);
        const verse = range.startContainer.parentElement.closest('.verse-block');

        if (verse) {
            const verseId = verse.dataset.verse;
            const text = verse.querySelector('.verse-text').textContent;
            const selectedText = selection.toString();
            const start = text.indexOf(selectedText);
            const end = start + selectedText.length;

            if (start !== -1) {
                await highlightManager.applyHighlight(verseId, start, end);
            }
        }
    });

