### **Day 67**
- **Material:** CLI structure
- **Exercise:** (30 min)
```rust
use clap::{Parser, Subcommand};

#[derive(Parser)]
struct Cli {
    #[command(subcommand)]
    command: Commands,
}

#[derive(Subcommand)]
enum Commands {
    Sync { },
    List { },
    Add { name: String },
}
```

### **Day 68**
- **PROJECT:** Wire up CLI to functions
- **Task:** (30 min)
```rust
fn main() -> Result<(), MetapacError> {
    let cli = Cli::parse();
    
    match cli.command {
        Commands::Sync => sync_packages()?,
        Commands::List => list_packages()?,
        Commands::Add { name } => add_package(&name)?,
    }
    
    Ok(())
}
```

