### **Day 46**
- **PROJECT:** Implement actual `apt install` execution
- **Task:** (30 min)
```rust
impl Installable for AptPackage {
    fn install(&self) -> Result<(), MetapacError> {
        let output = Command::new("apt")
            .arg("install")
            .arg("-y")
            .arg(&self.name)
            .output()?;
        
        if output.status.success() {
            Ok(())
        } else {
            Err(MetapacError::InstallFailed(self.name.clone()))
        }
    }
}
```

